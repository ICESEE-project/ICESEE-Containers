Bootstrap: docker
From: docker.io/bkyanjo/issm-lean:v1.0

%post
    set -eu

    apt-get update && apt-get install -y --no-install-recommends \
        curl \
        ca-certificates \
        && rm -rf /var/lib/apt/lists/*

    cat << 'EOF' > /opt/activate_issm.sh
#!/bin/sh
set -e

. /opt/runtime-env/issm-env.sh

export MLM_LICENSE_FILE="${MLM_LICENSE_FILE:-1711@matlablic.ecs.gatech.edu}"

if [ -f /opt/ISSM/etc/environment.sh ]; then
    set +u
    . /opt/ISSM/etc/environment.sh
    set -u
fi
EOF

    chmod +x /opt/activate_issm.sh

%environment
    export ISSM_DIR=/opt/ISSM
    export HDF5_MPI=ON
    export MLM_LICENSE_FILE=1711@matlablic.ecs.gatech.edu

%runscript
    #!/bin/sh
    set -e
    . /opt/activate_issm.sh

    if [ "$#" -gt 0 ]; then
        exec "$@"
    else
        exec /bin/bash
    fi

%test
    . /opt/activate_issm.sh
    test -f /opt/ISSM/etc/environment.sh
    mpicc --version
    matlab -batch "disp('MATLAB OK')"

%labels
    Author Brian Kyanjo
    Name ISSM Lean container
    Description MATLAB + lean MPICH/PETSc runtime with ISSM

%help
    This Apptainer container starts from docker.io/bkyanjo/issm-lean:v1.0.

    It provides:
      - MATLAB base image
      - Lean runtime for MPICH and PETSc
      - ISSM installed at /opt/ISSM
      - Precomputed runtime environment in /opt/runtime-env/issm-env.sh

    Typical usage:
      apptainer exec issm-env-lean.sif mpicc --version
      apptainer exec issm-env-lean.sif matlab -batch "disp('MATLAB OK')"
      apptainer shell issm-env-lean.sif