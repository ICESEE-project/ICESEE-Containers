Bootstrap: docker
From: docker.io/bkyanjo/combined-lean:v1.0

%post
    set -eu
    apt-get update && apt-get install -y --no-install-recommends \
        git \
        rsync \
    && rm -rf /var/lib/apt/lists/*

    cat << 'EOF' > /opt/set_persistent_dir.sh
#!/bin/sh
set -e

USER_NAME="${USER:-$(id -un 2>/dev/null || echo user)}"

choose_cache_base() {
    for cand in \
        "${APPTAINER_CACHEDIR:-}" \
        "${SINGULARITY_CACHEDIR:-}" \
        "/scratch/${USER_NAME}/combined_cache" \
        "/tmp/${USER_NAME}/combined_cache" \
        "/var/tmp/${USER_NAME}/combined_cache"
    do
        [ -n "$cand" ] || continue
        if mkdir -p "$cand" 2>/dev/null; then
            echo "$cand"
            return 0
        fi
    done
    return 1
}

BASE_CACHE="$(choose_cache_base)" || {
    echo "ERROR: could not create a writable cache directory" >&2
    exit 1
}

mkdir -p "${BASE_CACHE}/pyop2" \
         "${BASE_CACHE}/tsfc" \
         "${BASE_CACHE}/xdg" \
         "${BASE_CACHE}/matplotlib"

export PERSISTENT_DIR="${BASE_CACHE}"
export PYOP2_CACHE_DIR="${BASE_CACHE}/pyop2"
export FIREDRAKE_TSFC_KERNEL_CACHE_DIR="${BASE_CACHE}/tsfc"
export XDG_CACHE_HOME="${BASE_CACHE}/xdg"
export MPLCONFIGDIR="${BASE_CACHE}/matplotlib"
EOF

    cat << 'EOF' > /usr/local/bin/with-firedrake
#!/bin/sh
set -e
. /opt/set_persistent_dir.sh
if [ "$#" -eq 0 ]; then
    exec /usr/local/bin/activate-firedrake bash
else
    exec /usr/local/bin/activate-firedrake "$@"
fi
 . /opt/venv-icesee/bin/activate
EOF

    cat << 'EOF' > /usr/local/bin/with-icepack
#!/bin/sh
set -e
. /opt/set_persistent_dir.sh
if [ "$#" -eq 0 ]; then
    exec /usr/local/bin/activate-icepack bash
else
    exec /usr/local/bin/activate-icepack "$@"
fi
 . /opt/venv-icesee/bin/activate
EOF

    cat << 'EOF' > /usr/local/bin/with-icesee
#!/bin/sh
set -e
. /opt/set_persistent_dir.sh
if [ "$#" -eq 0 ]; then
    exec /usr/local/bin/activate-icesee bash
else
    exec /usr/local/bin/activate-icesee "$@"
fi
EOF

    cat << 'EOF' > /usr/local/bin/activate-issm-icesee
#!/bin/bash
set -e

# persistent runtime dirs
. /opt/set_persistent_dir.sh

# 1. Activate ICESEE first (gives Python + mpi4py + OpenMPI runtime)
if [ -f /usr/local/bin/activate-icesee ]; then
    . /usr/local/bin/activate-icesee
fi

# 2. Activate ISSM next (gives MATLAB + ISSM env)
export ISSM_DIR="${ISSM_DIR:-/opt/ISSM}"
if [ -f "${ISSM_DIR}/etc/environment.sh" ]; then
    . "${ISSM_DIR}/etc/environment.sh"
fi

if [ "$#" -eq 0 ]; then
    exec /bin/bash
else
    exec "$@"
fi
EOF


    cat << 'EOF' > /usr/local/bin/with-issm
#!/bin/bash
set -e
if [ "$#" -eq 0 ]; then
    exec /usr/local/bin/activate-issm-icesee bash
else
    exec /usr/local/bin/activate-issm-icesee "$@"
fi
EOF
    cat << 'EOF' > /usr/local/bin/issm-matlab
#!/bin/bash
set -e
. /opt/set_persistent_dir.sh

export ISSM_DIR="${ISSM_DIR:-/opt/ISSM}"
if [ -f "${ISSM_DIR}/etc/environment.sh" ]; then
    . "${ISSM_DIR}/etc/environment.sh"
fi

exec matlab -r "addpath('${ISSM_DIR}/bin','${ISSM_DIR}/lib');"
EOF

    mkdir -p /opt/matlab
    cat << 'EOF' > /opt/matlab/startup.m
isdir_bin = exist('/opt/ISSM/bin','dir');
isdir_lib = exist('/opt/ISSM/lib','dir');

if isdir_bin == 7
    addpath('/opt/ISSM/bin');
end
if isdir_lib == 7
    addpath('/opt/ISSM/lib');
end
EOF



    chmod +x /opt/set_persistent_dir.sh \
              /usr/local/bin/with-firedrake \
              /usr/local/bin/with-icepack \
              /usr/local/bin/with-icesee \
              /usr/local/bin/with-issm \
              /usr/local/bin/issm-matlab \
              /usr/local/bin/activate-issm-icesee

%environment
    export OMP_NUM_THREADS=1
    export OPENBLAS_NUM_THREADS=1
    export HDF5_MPI=ON
    export ISSM_DIR=/opt/ISSM
    export MLM_LICENSE_FILE="${MLM_LICENSE_FILE:-1711@matlablic.ecs.gatech.edu}"
    export MATLABPATH="/opt/matlab:${MATLABPATH:-}"
    export PATH="/usr/local/bin:${PATH}"
    export MPLCONFIGDIR="${APPTAINER_CACHEDIR:-/tmp}/matplotlib"
    export PMIX_MCA_psec=native
    export PYTHONPATH="/opt:\${PYTHONPATH:-}"
    
%runscript
    #!/bin/sh
    set -e
    . /opt/set_persistent_dir.sh

    if [ "$#" -gt 0 ]; then
        exec "$@"
    else
        exec /bin/bash
    fi

%test
    . /opt/set_persistent_dir.sh
    /usr/local/bin/with-firedrake python -c "import firedrake; print('firedrake ok')"
    /usr/local/bin/with-icepack python -c "import icepack; print('icepack ok')"
    /usr/local/bin/with-icesee python -c "import ICESEE; print('ICESEE ok')"
    /usr/local/bin/with-issm bash -c 'test -f /opt/ISSM/etc/environment.sh && echo "issm wrapper ok"'

%labels
    Author Brian Kyanjo
    Name Combined Lean container
    Description Combined runtime with built-in MATLAB base image

%help
    Combined container with:
      - Firedrake in /opt/venv-firedrake
      - Icepack in /opt/venv-icepack with access to Firedrake
      - ICESEE in /opt/venv-icesee
      - ISSM with MATLAB available inside the image runtime

    This image uses precomputed runtime environment wrappers and does not
    require Spack activation at container startup.

    Available wrappers:
      with-firedrake
      with-icepack
      with-icesee
      with-issm

    Basic usage:
      apptainer exec combined-env.sif with-firedrake python -c "import firedrake"
      apptainer exec combined-env.sif with-icepack python -c "import icepack"
      apptainer exec combined-env.sif with-icesee python -c "import ICESEE"
      apptainer exec combined-env.sif with-issm matlab -r "issmversion"

    Interactive shells:
      apptainer exec combined-env.sif with-firedrake
      apptainer exec combined-env.sif with-icepack
      apptainer exec combined-env.sif with-icesee
      apptainer exec combined-env.sif with-issm
