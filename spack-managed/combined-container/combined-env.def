Bootstrap: docker
From: docker.io/bkyanjo/combined-lean:v1.0

%post
    set -eu

    apt-get update && apt-get install -y --no-install-recommends \
        curl \
        ca-certificates \
        && rm -rf /var/lib/apt/lists/*

    cat << 'EOF' > /opt/set_persistent_dir.sh
#!/bin/sh
set -e

if [ -d "/scratch" ]; then
    PERSISTENT_DIR="/scratch/${USER:-$(id -un)}/combined_cache"
else
    PERSISTENT_DIR="/tmp/${USER:-$(id -un)}/combined_cache"
fi

mkdir -p "$PERSISTENT_DIR/pyop2"
mkdir -p "$PERSISTENT_DIR/tsfc"
mkdir -p "$PERSISTENT_DIR/xdg"

export PERSISTENT_DIR
export PYOP2_CACHE_DIR="$PERSISTENT_DIR/pyop2"
export FIREDRAKE_TSFC_KERNEL_CACHE_DIR="$PERSISTENT_DIR/tsfc"
export XDG_CACHE_HOME="$PERSISTENT_DIR/xdg"
EOF

    chmod +x /opt/set_persistent_dir.sh

%environment
    export OMP_NUM_THREADS=1
    export OPENBLAS_NUM_THREADS=1
    export HDF5_MPI=ON
    export MLM_LICENSE_FILE=1711@matlablic.ecs.gatech.edu

%runscript
    #!/bin/sh
    set -e
    . /opt/set_persistent_dir.sh

    if [ "$#" -gt 0 ]; then
        exec "$@"
    else
        exec /bin/bash
    fi

%test
    . /opt/set_persistent_dir.sh
    /usr/local/bin/activate-firedrake python -c "import firedrake; print('firedrake ok')"
    /usr/local/bin/activate-icepack python -c "import icepack; print('icepack ok')"
    /usr/local/bin/activate-icesee python -c "import ICESEE; print('ICESEE ok')"
    /usr/local/bin/activate-issm matlab -batch "disp('ISSM MATLAB OK')"

%labels
    Author Brian Kyanjo
    Name Combined Lean container

%help
    Lean combined container with:
      - Firedrake / Icepack / ICESEE on OpenMPI + PETSc 3.24
      - ISSM on MPICH + PETSc 3.22
      - MATLAB from the base image

    This image uses precomputed runtime environment wrappers and does not
    require Spack activation at container startup.

    Use one activation wrapper at a time:
      /usr/local/bin/activate-firedrake
      /usr/local/bin/activate-icepack
      /usr/local/bin/activate-icesee
      /usr/local/bin/activate-issm

    Typical usage:
      apptainer exec combined-env-lean.sif /usr/local/bin/activate-firedrake python -c "import firedrake"
      apptainer exec combined-env-lean.sif /usr/local/bin/activate-icepack python -c "import icepack"
      apptainer exec combined-env-Bootstrap: docker
From: docker.io/bkyanjo/combined-lean:v1.0

%post
    set -eu

    # Install necessary runtime packages
    apt-get update && apt-get install -y --no-install-recommends \
        curl \
        ca-certificates \
        && rm -rf /var/lib/apt/lists/*

    # Set up persistent directories
    cat << 'EOF' > /opt/set_persistent_dir.sh
#!/bin/sh
set -e

# Define where persistent data will be stored
if [ -d "/scratch" ]; then
    PERSISTENT_DIR="/scratch/${USER:-$(id -un)}/combined_cache"
else
    PERSISTENT_DIR="/tmp/${USER:-$(id -un)}/combined_cache"
fi

# Create directories for caches
mkdir -p "$PERSISTENT_DIR/pyop2"
mkdir -p "$PERSISTENT_DIR/tsfc"
mkdir -p "$PERSISTENT_DIR/xdg"

# Export environment variables for persistent cache locations
export PERSISTENT_DIR
export PYOP2_CACHE_DIR="$PERSISTENT_DIR/pyop2"
export FIREDRAKE_TSFC_KERNEL_CACHE_DIR="$PERSISTENT_DIR/tsfc"
export XDG_CACHE_HOME="$PERSISTENT_DIR/xdg"
EOF

    chmod +x /opt/set_persistent_dir.sh

%environment
    export OMP_NUM_THREADS=1
    export OPENBLAS_NUM_THREADS=1
    export HDF5_MPI=ON
    export MLM_LICENSE_FILE=1711@matlablic.ecs.gatech.edu

%runscript
    #!/bin/bash
    set -e

    # Set up persistent cache directories
    . /opt/set_persistent_dir.sh

    # Command-line argument (the environment to activate)
    ENV_NAME="$1"
    shift  # Remove the first argument (the environment name)

    # Process with the appropriate environment
    case "$ENV_NAME" in
        with-firedrake)
            source /opt/runtime-env/firedrake-env.sh
            ;;
        with-icepack)
            source /opt/runtime-env/icepack-env.sh
            ;;
        with-icesee)
            source /opt/runtime-env/icesee-env.sh
            ;;
        with-issm)
            source /opt/runtime-env/issm-env.sh
            ;;
        *)
            echo "Error: Unknown environment: $ENV_NAME"
            exit 1
            ;;
    esac

    # Execute the passed command
    exec "$@"

%test
    # Test the environments for each toolchain
    . /opt/set_persistent_dir.sh
    apptainer exec combined-env-lean.sif with-firedrake python -c "import firedrake; print('firedrake ok')"
    apptainer exec combined-env-lean.sif with-icepack python -c "import icepack; print('icepack ok')"
    apptainer exec combined-env-lean.sif with-icesee python -c "import ICESEE; print('ICESEE ok')"
    apptainer exec combined-env-lean.sif with-issm matlab -batch "disp('ISSM MATLAB OK')"

%labels
    Author Brian Kyanjo
    Name Combined Lean container

%help
    Lean combined container with:
      - Firedrake / Icepack / ICESEE on OpenMPI + PETSc 3.24
      - ISSM on MPICH + PETSc 3.22
      - MATLAB from the base image

    This image uses precomputed runtime environment wrappers and does not
    require Spack activation at container startup.

    Use one of the following environment wrappers:
      with-firedrake
      with-icepack
      with-icesee
      with-issm

    Typical usage:
      apptainer exec combined-env-lean.sif with-firedrake python -c "import firedrake"
      apptainer exec combined-env-lean.sif with-icepack python -c "import icepack"
      apptainer exec combined-env-lean.sif with-icesee python -c "import ICESEE"
      apptainer exec combined-env-lean.sif with-issm matlab -batch "disp('MATLAB OK')"lean.sif /usr/local/bin/activate-icesee python -c "import ICESEE"
      apptainer exec combined-env-lean.sif /usr/local/bin/activate-issm matlab -batch "disp('MATLAB OK')"